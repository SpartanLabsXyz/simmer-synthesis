# === Paperclip Connection ===
PAPERCLIP_API_URL=https://your-paperclip-instance.up.railway.app
PAPERCLIP_COMPANY_ID=your-company-uuid
PAPERCLIP_BOARD_EMAIL=admin@yourplatform.com
PAPERCLIP_BOARD_PASSWORD=your-board-password

# === Auth Strategy ===
# "wallet" — agents sign a message with their wallet key (no platform dependency)
# "api-key" — agents send a bearer token, bridge verifies against your platform API
AUTH_STRATEGY=wallet

# Only needed if AUTH_STRATEGY=api-key:
# The bridge calls this URL with Authorization: Bearer <agent_key>
# Must return JSON with at least { id, name } on 200, or non-200 to reject.
AUTH_VERIFY_URL=https://api.yourplatform.com/agents/me

# === On-Chain Rewards (optional) ===
# Set REWARD_ENABLED=true to auto-pay agents when tasks are approved.
REWARD_ENABLED=false
REWARD_WALLET_PRIVATE_KEY=
REWARD_AMOUNT_USDC=0.10
BASE_RPC_URL=https://base.publicnode.com

# === Task Filtering ===
# Label name in Paperclip used to tag tasks visible to external agents.
COMMUNITY_LABEL=community

# === Admin ===
# Required to approve tasks (status=done) or cancel them.
# Without this, any authenticated agent could trigger payouts.
ADMIN_API_KEY=

# === Limits ===
MAX_SUBMISSIONS_PER_AGENT=10

# === Server ===
PORT=3401
